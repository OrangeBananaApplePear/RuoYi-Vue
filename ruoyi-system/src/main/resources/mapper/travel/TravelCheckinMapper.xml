<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.travel.TravelCheckinMapper">

    <resultMap type="com.ruoyi.system.domain.travel.TravelCheckin" id="TravelCheckinResult">
        <id     property="checkinId"    column="checkin_id"     />
        <result property="userId"        column="user_id"        />
        <result property="spotId"        column="spot_id"        />
        <result property="cityId"       column="city_id"        />
        <result property="content"       column="content"        />
        <result property="images"        column="images"        />
        <result property="locationLat"  column="location_lat"  />
        <result property="locationLng"  column="location_lng"  />
        <result property="isPublic"     column="is_public"      />
        <result property="likeCount"     column="like_count"    />
        <result property="commentCount" column="comment_count" />
        <result property="status"       column="status"        />
        <result property="delFlag"      column="del_flag"      />
        <result property="createBy"      column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <!-- 非数据库字段 -->
        <result property="nickname"     column="nickname"       />
        <result property="avatar"       column="avatar"         />
        <result property="spotName"     column="spot_name"      />
        <result property="cityName"     column="city_name"      />
    </resultMap>

    <sql id="selectTravelCheckinVo">
        select c.checkin_id, c.user_id, c.spot_id, c.city_id, c.content, c.images,
               c.location_lat, c.location_lng, c.is_public, c.like_count, c.comment_count,
               c.status, c.del_flag, c.create_by, c.create_time, c.update_by, c.update_time,
               u.nickname, u.avatar, s.spot_name, t.city_name
        from travel_checkin c
        left join travel_user u on c.user_id = u.user_id
        left join travel_spot s on c.spot_id = s.spot_id
        left join travel_city t on c.city_id = t.city_id
    </sql>

    <select id="selectTravelCheckinList" parameterType="com.ruoyi.system.domain.travel.TravelCheckin" resultMap="TravelCheckinResult">
        <include refid="selectTravelCheckinVo"/>
        <where>
            c.del_flag = '0'
            <if test="userId != null">
                AND c.user_id = #{userId}
            </if>
            <if test="spotId != null">
                AND c.spot_id = #{spotId}
            </if>
            <if test="cityId != null">
                AND c.city_id = #{cityId}
            </if>
            <if test="isPublic != null and isPublic != ''">
                AND c.is_public = #{isPublic}
            </if>
        </where>
        order by c.create_time desc
    </select>

    <select id="selectTravelCheckinById" parameterType="Long" resultMap="TravelCheckinResult">
        <include refid="selectTravelCheckinVo"/>
        where c.checkin_id = #{checkinId}
    </select>

    <select id="selectPublicCheckinsBySpotId" parameterType="Long" resultMap="TravelCheckinResult">
        <include refid="selectTravelCheckinVo"/>
        where c.spot_id = #{spotId} and c.del_flag = '0' and c.status = '0' and c.is_public = '1'
        order by c.create_time desc
    </select>

    <select id="selectCheckinsByUserId" parameterType="Long" resultMap="TravelCheckinResult">
        <include refid="selectTravelCheckinVo"/>
        where c.user_id = #{userId} and c.del_flag = '0' and c.status = '0'
        order by c.create_time desc
    </select>

    <select id="selectUserCheckinsBySpotId" resultMap="TravelCheckinResult">
        <include refid="selectTravelCheckinVo"/>
        where c.user_id = #{userId} and c.spot_id = #{spotId} and c.del_flag = '0'
        order by c.create_time desc
    </select>

    <insert id="insertTravelCheckin" parameterType="com.ruoyi.system.domain.travel.TravelCheckin" useGeneratedKeys="true" keyProperty="checkinId">
        insert into travel_checkin
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="spotId != null">spot_id,</if>
            <if test="cityId != null">city_id,</if>
            <if test="content != null">content,</if>
            <if test="images != null">images,</if>
            <if test="locationLat != null">location_lat,</if>
            <if test="locationLng != null">location_lng,</if>
            <if test="isPublic != null">is_public,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="spotId != null">#{spotId},</if>
            <if test="cityId != null">#{cityId},</if>
            <if test="content != null">#{content},</if>
            <if test="images != null">#{images},</if>
            <if test="locationLat != null">#{locationLat},</if>
            <if test="locationLng != null">#{locationLng},</if>
            <if test="isPublic != null">#{isPublic},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateTravelCheckin" parameterType="com.ruoyi.system.domain.travel.TravelCheckin">
        update travel_checkin
        <trim prefix="SET" suffixOverrides=",">
            <if test="content != null">content = #{content},</if>
            <if test="images != null">images = #{images},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where checkin_id = #{checkinId}
    </update>

    <update id="deleteTravelCheckinById" parameterType="Long">
        update travel_checkin set del_flag = '1' where checkin_id = #{checkinId}
    </update>

    <update id="deleteTravelCheckinByIds" parameterType="Long">
        update travel_checkin set del_flag = '1' where checkin_id in
        <foreach item="checkinId" collection="array" open="(" separator="," close=")">
            #{checkinId}
        </foreach>
    </update>

    <update id="incrementLikeCount" parameterType="Long">
        update travel_checkin set like_count = like_count + 1 where checkin_id = #{checkinId}
    </update>

    <update id="decrementLikeCount" parameterType="Long">
        update travel_checkin set like_count = like_count - 1 where checkin_id = #{checkinId} and like_count > 0
    </update>

    <update id="incrementCommentCount" parameterType="Long">
        update travel_checkin set comment_count = comment_count + 1 where checkin_id = #{checkinId}
    </update>

    <update id="decrementCommentCount" parameterType="Long">
        update travel_checkin set comment_count = comment_count - 1 where checkin_id = #{checkinId} and comment_count > 0
    </update>

</mapper>
