<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.travel.TravelCityMapper">

    <resultMap type="com.ruoyi.system.domain.travel.TravelCity" id="TravelCityResult">
        <id     property="cityId"    column="city_id"    />
        <result property="parentId"  column="parent_id"  />
        <result property="cityName"  column="city_name"  />
        <result property="cityCode"  column="city_code"  />
        <result property="level"     column="level"     />
        <result property="latitude"  column="latitude"  />
        <result property="longitude" column="longitude" />
        <result property="sort"      column="sort"      />
        <result property="status"    column="status"    />
        <result property="delFlag"  column="del_flag"  />
        <result property="createBy"  column="create_by"  />
        <result property="createTime" column="create_time" />
        <result property="updateBy"  column="update_by"  />
        <result property="updateTime" column="update_time" />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTravelCityVo">
        select city_id, parent_id, city_name, city_code, level, latitude, longitude, 
               sort, status, del_flag, create_by, create_time, update_by, update_time, remark
        from travel_city
    </sql>

    <select id="selectTravelCityList" parameterType="com.ruoyi.system.domain.travel.TravelCity" resultMap="TravelCityResult">
        <include refid="selectTravelCityVo"/>
        <where>
            del_flag = '0'
            <if test="cityName != null and cityName != ''">
                AND city_name like concat('%', #{cityName}, '%')
            </if>
            <if test="level != null">
                AND level = #{level}
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort, city_id
    </select>

    <select id="selectTravelCityById" parameterType="Long" resultMap="TravelCityResult">
        <include refid="selectTravelCityVo"/>
        where city_id = #{cityId}
    </select>

    <select id="selectTravelCityByParentId" parameterType="Long" resultMap="TravelCityResult">
        <include refid="selectTravelCityVo"/>
        where parent_id = #{parentId} and del_flag = '0' and status = '0'
        order by sort, city_id
    </select>

    <select id="selectCheckedCitiesByUserId" parameterType="Long" resultMap="TravelCityResult">
        select c.city_id, c.parent_id, c.city_name, c.city_code, c.level, 
               c.latitude, c.longitude, c.sort, c.status, c.del_flag
        from travel_city c
        inner join travel_footprint f on c.city_id = f.city_id
        where f.user_id = #{userId} and f.type = '1' and c.del_flag = '0'
    </select>

    <insert id="insertTravelCity" parameterType="com.ruoyi.system.domain.travel.TravelCity" useGeneratedKeys="true" keyProperty="cityId">
        insert into travel_city
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="cityName != null and cityName != ''">city_name,</if>
            <if test="cityCode != null">city_code,</if>
            <if test="level != null">level,</if>
            <if test="latitude != null">latitude,</if>
            <if test="longitude != null">longitude,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="cityName != null and cityName != ''">#{cityName},</if>
            <if test="cityCode != null">#{cityCode},</if>
            <if test="level != null">#{level},</if>
            <if test="latitude != null">#{latitude},</if>
            <if test="longitude != null">#{longitude},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateTravelCity" parameterType="com.ruoyi.system.domain.travel.TravelCity">
        update travel_city
        <trim prefix="SET" suffixOverrides=",">
            <if test="cityName != null and cityName != ''">city_name = #{cityName},</if>
            <if test="cityCode != null">city_code = #{cityCode},</if>
            <if test="level != null">level = #{level},</if>
            <if test="latitude != null">latitude = #{latitude},</if>
            <if test="longitude != null">longitude = #{longitude},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where city_id = #{cityId}
    </update>

    <update id="deleteTravelCityById" parameterType="Long">
        update travel_city set del_flag = '1' where city_id = #{cityId}
    </update>

    <update id="deleteTravelCityByIds" parameterType="Long">
        update travel_city set del_flag = '1' where city_id in
        <foreach item="cityId" collection="array" open="(" separator="," close=")">
            #{cityId}
        </foreach>
    </update>

</mapper>
