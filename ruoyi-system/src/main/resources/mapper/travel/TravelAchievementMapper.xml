<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.travel.TravelAchievementMapper">

    <resultMap type="com.ruoyi.system.domain.travel.TravelAchievement" id="TravelAchievementResult">
        <id     property="achievementId"    column="achievement_id"    />
        <result property="achievementName"   column="achievement_name"   />
        <result property="icon"             column="icon"              />
        <result property="description"      column="description"       />
        <result property="conditionType"    column="condition_type"    />
        <result property="conditionCities"  column="condition_cities"  />
        <result property="conditionSpots"   column="condition_spots"   />
        <result property="timeType"        column="time_type"         />
        <result property="months"           column="months"            />
        <result property="status"           column="status"           />
        <result property="createTime"       column="create_time"      />
        <result property="updateTime"       column="update_time"      />
        <result property="remark"           column="remark"           />
    </resultMap>

    <sql id="selectTravelAchievementVo">
        select achievement_id, achievement_name, icon, description, condition_type, 
               condition_cities, condition_spots, time_type, months, status, 
               create_time, update_time, remark
        from travel_achievement
    </sql>

    <select id="selectTravelAchievementList" parameterType="com.ruoyi.system.domain.travel.TravelAchievement" resultMap="TravelAchievementResult">
        <include refid="selectTravelAchievementVo"/>
        <where>
            <if test="achievementName != null and achievementName != ''">
                AND achievement_name like concat('%', #{achievementName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectTravelAchievementById" parameterType="Long" resultMap="TravelAchievementResult">
        <include refid="selectTravelAchievementVo"/>
        where achievement_id = #{achievementId}
    </select>

    <select id="selectEnabledAchievements" resultMap="TravelAchievementResult">
        <include refid="selectTravelAchievementVo"/>
        where status = '0'
    </select>

    <insert id="insertTravelAchievement" parameterType="com.ruoyi.system.domain.travel.TravelAchievement" useGeneratedKeys="true" keyProperty="achievementId">
        insert into travel_achievement
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="achievementName != null and achievementName != ''">achievement_name,</if>
            <if test="icon != null">icon,</if>
            <if test="description != null">description,</if>
            <if test="conditionType != null">condition_type,</if>
            <if test="conditionCities != null">condition_cities,</if>
            <if test="conditionSpots != null">condition_spots,</if>
            <if test="timeType != null">time_type,</if>
            <if test="months != null">months,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="achievementName != null and achievementName != ''">#{achievementName},</if>
            <if test="icon != null">#{icon},</if>
            <if test="description != null">#{description},</if>
            <if test="conditionType != null">#{conditionType},</if>
            <if test="conditionCities != null">#{conditionCities},</if>
            <if test="conditionSpots != null">#{conditionSpots},</if>
            <if test="timeType != null">#{timeType},</if>
            <if test="months != null">#{months},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateTravelAchievement" parameterType="com.ruoyi.system.domain.travel.TravelAchievement">
        update travel_achievement
        <trim prefix="SET" suffixOverrides=",">
            <if test="achievementName != null and achievementName != ''">achievement_name = #{achievementName},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="description != null">description = #{description},</if>
            <if test="conditionType != null">condition_type = #{conditionType},</if>
            <if test="conditionCities != null">condition_cities = #{conditionCities},</if>
            <if test="conditionSpots != null">condition_spots = #{conditionSpots},</if>
            <if test="timeType != null">time_type = #{timeType},</if>
            <if test="months != null">months = #{months},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where achievement_id = #{achievementId}
    </update>

    <delete id="deleteTravelAchievementById" parameterType="Long">
        delete from travel_achievement where achievement_id = #{achievementId}
    </delete>

    <delete id="deleteTravelAchievementByIds" parameterType="Long">
        delete from travel_achievement where achievement_id in
        <foreach item="achievementId" collection="array" open="(" separator="," close=")">
            #{achievementId}
        </foreach>
    </delete>

</mapper>
